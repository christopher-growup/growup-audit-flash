        "jsCode": "// Recuperer l'ID du contact Notion (cree ou existant)\nconst data = $('Merge Brevo').first().json;\nlet notionContactId = null;\nlet notionContactUrl = null;\n\ntry {\n  const existing = $('Notion — MAJ Contact').first().json;\n  notionContactId = existing.id;\n  notionContactUrl = existing.url;\n} catch(e) {}\n\nif (!notionContactId) {\n  try {\n    const created = $('Notion — Creer Contact').first().json;\n    notionContactId = created.id;\n    notionContactUrl = created.url;\n  } catch(e) {}\n}\n\nreturn [{ json: { ...data, notionContactId, notionContactUrl } }];"
